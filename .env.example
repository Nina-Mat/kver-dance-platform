# Скопируйте в .env для локальной разработки:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)

# ОБЯЗАТЕЛЬНО смените на продакшене (случайная строка 50+ символов):
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-do-not-use-in-production

# True — локально, False — на хостинге
DEBUG=True

# Локально
ALLOWED_HOSTS=127.0.0.1,localhost

# На PythonAnywhere задайте в Web → Environment variables (пример):
# DEBUG=False
# ALLOWED_HOSTS=вашлогин.pythonanywhere.com
# CSRF_TRUSTED_ORIGINS=https://вашлогин.pythonanywhere.com
# SECRET_KEY=ваш-случайный-ключ-из-команды-выше

CSRF_TRUSTED_ORIGINS=

# HTTPS-куки (True на PythonAnywhere; False если тестируете DEBUG=False локально по http)
USE_HTTPS=True

# Имя файла SQLite (по умолчанию db.sqlite3 в корне проекта)
DB_NAME=db.sqlite3

# Опционально: превью YouTube при загрузке каверов
YOUTUBE_API_KEY=
